{
  "name": "dotfiles-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Web UI for managing dotfiles installation via GNU Stow",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "esbuild src/client/app.ts --bundle --platform=browser --target=es2022 --format=iife --outfile=public/app.js",
    "build": "npm run build:server && npm run build:client",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && npm run typecheck:client",
    "start": "node dist/server/index.js",
    "dev": "npm run build && node --watch dist/server/index.js",
    "test": "npm run build:server && node --test test/server.test.js"
  },
  "dependencies": {
    "express": "^4.18.3"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "esbuild@0.28.0": true
  }
}
