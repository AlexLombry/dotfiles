# Justfile

# Default recipe (equivalent to `task --list`)
default:
	@just --list

# Configure macOS defaults
os:
	@bash macos.sh
	@echo "Setup OS done!"

# Install Homebrew bundle from BrewFile
brew:
	HOMEBREW_NO_AUTO_UPDATE=1 brew bundle --file=BrewFile

# Apply symlinks with GNU Stow
# WARNING: --adopt moves existing $HOME files INTO the stow dir, overwriting tracked versions.
# Safe on a clean machine; dangerous on re-runs with local modifications.
stow:
	@cd $HOME/dotfiles/stow && \
	stow --adopt -t "$HOME" zsh git config apps work
	@echo "Symlinks applied!"

# Install languages and tools with Mise
mise:
	mise install
	mise use -g

# Install NvChad
chad:
	@if [ ! -d ~/.config/nvim ]; then \
		git clone https://github.com/NvChad/NvChad ~/.config/nvim --depth 1 && nvim; \
	else \
		echo "NvChad already installed at ~/.config/nvim"; \
	fi

# Create GPG backup password
gpg-pass:
	security add-generic-password -a "$$USER" -s backup-gpg -w -U

# Unlink all stow symlinks
unstow:
	@cd $HOME/dotfiles/stow && stow -D -t "$HOME" zsh git config apps work
	@echo "Symlinks removed!"

# Run upd8r to update all package managers
update:
	@bash $HOME/dotfiles/install/tools/upd8r/upd8r.sh

# Benchmark shell startup time
bench:
	@for i in 1 2 3; do /usr/bin/time zsh -i -c exit; done

# Generate shell completions for uv/uvx (run once after brew)
completions:
	@mkdir -p ~/.zsh/completions
	@uv generate-shell-completion zsh > ~/.zsh/completions/_uv
	@uvx --generate-shell-completion zsh > ~/.zsh/completions/_uvx
	@echo "Completions generated!"

# Complete setup for a new MacBook
setup: stow os brew mise completions
	@echo "🚀 MacBook Setup Complete! Please restart your terminal."
